default_platform(:ios)

platform :ios do

  before_all do
    # Generate the Xcode project from the XcodeGen spec
    Dir.chdir("..") do
      sh("xcodegen", "generate")
    end
  end

  # ── Test lane ─────────────────────────────────────────────
  desc "Build and run unit tests"
  lane :test do
    scan(
      project: "Thump.xcodeproj",
      scheme: "Thump",
      devices: ["iPhone 15 Pro"],
      clean: true,
      code_coverage: true,
      output_directory: "./fastlane/test_output"
    )
  end

  # ── Beta lane ─────────────────────────────────────────────
  desc "Build and upload to TestFlight"
  lane :beta do
    gym(
      project: "Thump.xcodeproj",
      scheme: "Thump",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: "./fastlane/build_output"
    )

    pilot(
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end

end
